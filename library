-- ──────────────────────────────────────────────────
-- Instance Factory
-- ──────────────────────────────────────────────────
local function new(class, props, parent)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do obj[k] = v end
    if parent then obj.Parent = parent end
    return obj
end

