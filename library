        -- ── Dropdown ──────────────────────────────
        function Tab:CreateDropdown(DSettings)
            DSettings.Type = "Dropdown"
            if type(DSettings.CurrentOption) == "string" then
                DSettings.CurrentOption = { DSettings.CurrentOption }
            end
            DSettings.CurrentOption = DSettings.CurrentOption or {}

            local isOpen = false
            local rowH = 42

            local container = new("Frame", {
                Name = DSettings.Name,
                Size = UDim2.new(1, 0, 0, rowH),
                BackgroundColor3 = C.ElementBG,
                BackgroundTransparency = 0,
                BorderSizePixel = 0,
                LayoutOrder = rowCount,
                ClipsDescendants = true,
                ZIndex = 3,
            }, page)
            rowCount += 1

            new("Frame", {
                Size = UDim2.new(1, 0, 0, 1),
                Position = UDim2.new(0, 0, 0, rowH - 1),
                BackgroundColor3 = C.StrokeDim,
                BackgroundTransparency = 0.7,
                BorderSizePixel = 0,
                ZIndex = 3,
            }, container)

            local headerLabel = new("TextLabel", {
                Size = UDim2.new(0.55, 0, 0, rowH),
                Position = UDim2.new(0, 14, 0, 0),
                BackgroundTransparency = 1,
                Text = DSettings.Name or "Dropdown",
                TextColor3 = C.Text,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 4,
            }, container)

            local selectedText = new("TextLabel", {
                Size = UDim2.new(0.4, -30, 0, rowH),
                Position = UDim2.new(0.6, -10, 0, 0),
                BackgroundTransparency = 1,
                Text = #DSettings.CurrentOption > 0 and DSettings.CurrentOption[1] or "None",
                TextColor3 = C.AccentGlow,
                TextSize = 12,
                Font = Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 4,
            }, container)

            -- Arrow
            local arrow = new("TextLabel", {
                Size = UDim2.new(0, 16, 0, rowH),
                Position = UDim2.new(1, -24, 0, 0),
                BackgroundTransparency = 1,
                Text = "▾",
                TextColor3 = C.TextDim,
                TextSize = 12,
                Font = Enum.Font.GothamBold,
                ZIndex = 4,
            }, container)

            -- Options list
            local optList = new("Frame", {
                Size = UDim2.new(1, 0, 0, 0),
                Position = UDim2.new(0, 0, 0, rowH),
                BackgroundColor3 = C.DropBG,
                BorderSizePixel = 0,
                ZIndex = 4,
            }, container)
            new("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 0) }, optList)

            local function buildOptions()
                for _, c in ipairs(optList:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                for i, opt in ipairs(DSettings.Options or {}) do
                    local optRow = new("Frame", {
                        Size = UDim2.new(1, 0, 0, 34),
                        BackgroundColor3 = table.find(DSettings.CurrentOption, opt)
                            and C.DropSel or C.DropBG,
                        BackgroundTransparency = 0,
                        BorderSizePixel = 0,
                        LayoutOrder = i,
                        ZIndex = 5,
                    }, optList)

                    new("TextLabel", {
                        Size = UDim2.new(1, -14, 1, 0),
                        Position = UDim2.new(0, 14, 0, 0),
                        BackgroundTransparency = 1,
                        Text = opt,
                        TextColor3 = table.find(DSettings.CurrentOption, opt) and C.AccentGlow or C.TextDim,
                        TextSize = 12,
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 6,
                    }, optRow)

                    local ib = new("TextButton", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text = "",
                        ZIndex = 7,
                    }, optRow)

                    ib.MouseButton1Click:Connect(function()
                        if not DSettings.MultipleOptions then
                            DSettings.CurrentOption = { opt }
                            selectedText.Text = opt
                            -- close
                            isOpen = false
                            local listH = #DSettings.Options * 34
                            tween(container, 0.25, { Size = UDim2.new(1, 0, 0, rowH) })
                            arrow.Text = "▾"
                        else
                            local idx = table.find(DSettings.CurrentOption, opt)
                            if idx then
                                table.remove(DSettings.CurrentOption, idx)
                            else
                                table.insert(DSettings.CurrentOption, opt)
                            end
                            if #DSettings.CurrentOption == 0 then
                                selectedText.Text = "None"
                            elseif #DSettings.CurrentOption == 1 then
                                selectedText.Text = DSettings.CurrentOption[1]
                            else
                                selectedText.Text = "Various"
                            end
                        end
                        buildOptions()
                        pcall(DSettings.Callback, DSettings.CurrentOption)
                        if DSettings.Flag then saveCfg() end
                    end)

                    optRow.MouseEnter:Connect(function()
                        tween(optRow, 0.15, { BackgroundColor3 = C.ElementHov })
                    end)
                    optRow.MouseLeave:Connect(function()
                        local sel = table.find(DSettings.CurrentOption, opt)
                        tween(optRow, 0.15, { BackgroundColor3 = sel and C.DropSel or C.DropBG })
                    end)
                end

                local listH = #(DSettings.Options or {}) * 34
                optList.Size = UDim2.new(1, 0, 0, listH)
            end
            buildOptions()

            local interact = new("TextButton", {
                Size = UDim2.new(1, 0, 0, rowH),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 8,
            }, container)

            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    local listH = #(DSettings.Options or {}) * 34
                    tween(container, 0.25, { Size = UDim2.new(1, 0, 0, rowH + listH) })
                    arrow.Text = "▴"
                else
                    tween(container, 0.25, { Size = UDim2.new(1, 0, 0, rowH) })
                    arrow.Text = "▾"
                end
            end)

            container.MouseEnter:Connect(function() tween(container, 0.2, { BackgroundColor3 = C.ElementHov }) end)
            container.MouseLeave:Connect(function() tween(container, 0.2, { BackgroundColor3 = C.ElementBG }) end)

            function DSettings:Set(opt)
                if type(opt) == "string" then opt = { opt } end
                DSettings.CurrentOption = opt
                selectedText.Text = #opt == 0 and "None" or (#opt == 1 and opt[1] or "Various")
                buildOptions()
                pcall(DSettings.Callback, DSettings.CurrentOption)
            end

            function DSettings:Refresh(newOpts)
                DSettings.Options = newOpts
                buildOptions()
            end

            if DSettings.Flag then VonHub.Flags[DSettings.Flag] = DSettings end
            return DSettings
        end

        -- ── Keybind ───────────────────────────────
        function Tab:CreateKeybind(KSettings)
            KSettings.Type = "Keybind"
            local row, lbl = makeRow(KSettings.Name or "Keybind", rowCount)
            rowCount += 1

            local listening = false

            local pill = new("TextButton", {
                Size = UDim2.new(0, 40, 0, 20),
                Position = UDim2.new(1, -52, 0.5, -10),
                BackgroundColor3 = C.InputBG,
                BorderSizePixel = 0,
                Text = KSettings.CurrentKeybind and ("[" .. KSettings.CurrentKeybind .. "]") or "[..]",
                TextColor3 = C.TextDim,
                TextSize = 10,
                Font = Enum.Font.GothamBold,
                ZIndex = 5,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 4) }, pill)
            new("UIStroke", { Color = C.StrokeDim, Thickness = 1, Transparency = 0.4 }, pill)

            pill.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                pill.Text = "···"
                tween(pill, 0.2, { TextColor3 = C.AccentGlow })
                local conn
                conn = UserInputService.InputBegan:Connect(function(inp, proc)
                    if inp.KeyCode ~= Enum.KeyCode.Unknown and not proc then
                        local keyName = inp.KeyCode.Name
                        KSettings.CurrentKeybind = keyName
                        pill.Text = "[" .. keyName .. "]"
                        tween(pill, 0.2, { TextColor3 = C.TextDim })
                        listening = false
                        conn:Disconnect()
                        if not KSettings.HoldToInteract and KSettings.CallOnChange then
                            pcall(KSettings.Callback, keyName)
                        end
                        if KSettings.Flag then saveCfg() end
                    end
                end)
            end)

            -- Trigger callback on press
            if not KSettings.CallOnChange then
                UserInputService.InputBegan:Connect(function(inp, proc)
                    if proc or listening then return end
                    if KSettings.CurrentKeybind and inp.KeyCode == Enum.KeyCode[KSettings.CurrentKeybind] then
                        if KSettings.HoldToInteract then
                            local held = true
                            local upConn
                            upConn = UserInputService.InputEnded:Connect(function(i)
                                if i.KeyCode == Enum.KeyCode[KSettings.CurrentKeybind] then
                                    held = false
                                    pcall(KSettings.Callback, false)
                                    upConn:Disconnect()
                                end
                            end)
                            task.spawn(function()
                                task.wait(0.2)
                                while held do
                                    pcall(KSettings.Callback, true)
                                    task.wait(0.05)
                                end
                            end)
                        else
                            pcall(KSettings.Callback)
                        end
                    end
                end)
            end

            function KSettings:Set(key)
                KSettings.CurrentKeybind = key
                pill.Text = "[" .. key .. "]"
            end

            if KSettings.Flag then VonHub.Flags[KSettings.Flag] = KSettings end
            return KSettings
        end

