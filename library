        -- ── Toggle ────────────────────────────────
        function Tab:CreateToggle(TSettings)
            TSettings.Type = "Toggle"
            TSettings.CurrentValue = TSettings.CurrentValue or false

            local row, lbl = makeRow(TSettings.Name or "Toggle", rowCount)
            rowCount += 1

            -- Toggle track
            local trackW, trackH = 40, 20
            local track = new("Frame", {
                Size = UDim2.new(0, trackW, 0, trackH),
                Position = UDim2.new(1, -(trackW + 12), 0.5, -trackH/2),
                BackgroundColor3 = C.ToggleOff,
                BorderSizePixel = 0,
                ZIndex = 4,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 10) }, track)
            new("UIStroke", { Color = C.StrokeDim, Thickness = 1, Transparency = 0.3 }, track)

            -- Diamond knob
            local knobSize = 11
            local knob = new("Frame", {
                Size = UDim2.new(0, knobSize, 0, knobSize),
                Position = UDim2.new(0, 5, 0.5, -knobSize/2),
                Rotation = 45,
                BackgroundColor3 = C.Knob,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, track)
            new("UICorner", { CornerRadius = UDim.new(0, 2) }, knob)
            new("UIStroke", { Color = C.Stroke, Thickness = 1, Transparency = 0.4 }, knob)

            local function applyToggle(val, fireCallback)
                TSettings.CurrentValue = val
                if val then
                    tween(track, 0.25, { BackgroundColor3 = C.ToggleOn })
                    tween(knob, 0.22, { Position = UDim2.new(0, trackW - knobSize - 5, 0.5, -knobSize/2), BackgroundColor3 = C.KnobOn })
                else
                    tween(track, 0.25, { BackgroundColor3 = C.ToggleOff })
                    tween(knob, 0.22, { Position = UDim2.new(0, 5, 0.5, -knobSize/2), BackgroundColor3 = C.Knob })
                end
                if fireCallback then
                    local ok, err = pcall(TSettings.Callback, val)
                    if not ok then warn("VonHub Toggle Error: " .. tostring(err)) end
                end
                if TSettings.Flag then saveCfg() end
            end

            applyToggle(TSettings.CurrentValue, false)

            local interact = new("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 6,
            }, row)
            interact.MouseButton1Click:Connect(function()
                applyToggle(not TSettings.CurrentValue, true)
            end)

            function TSettings:Set(v) applyToggle(v, true) end

            if TSettings.Flag then
                VonHub.Flags[TSettings.Flag] = TSettings
            end
            return TSettings
        end

        -- ── Slider ────────────────────────────────
        function Tab:CreateSlider(SSettings)
            SSettings.Type = "Slider"
            local row, lbl = makeRow(SSettings.Name or "Slider", rowCount)
            rowCount += 1
            row.Size = UDim2.new(1, 0, 0, 54)

            local min, max = SSettings.Range[1], SSettings.Range[2]
            local val = math.clamp(SSettings.CurrentValue or min, min, max)
            local inc = SSettings.Increment or 1

            local valLabel = new("TextLabel", {
                Size = UDim2.new(0, 60, 0, 14),
                Position = UDim2.new(1, -74, 0, 14),
                BackgroundTransparency = 1,
                Text = tostring(val) .. (SSettings.Suffix and " " .. SSettings.Suffix or ""),
                TextColor3 = C.AccentGlow,
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 4,
            }, row)

            -- Track bar
            local trackBar = new("Frame", {
                Size = UDim2.new(1, -28, 0, 5),
                Position = UDim2.new(0, 14, 0, 34),
                BackgroundColor3 = C.SliderBG,
                BorderSizePixel = 0,
                ZIndex = 4,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 3) }, trackBar)
            new("UIStroke", { Color = C.StrokeDim, Thickness = 1, Transparency = 0.4 }, trackBar)

            local fillBar = new("Frame", {
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = C.SliderFill,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, trackBar)
            new("UICorner", { CornerRadius = UDim.new(0, 3) }, fillBar)

            local function setSliderVal(newVal, fire)
                newVal = math.clamp(math.floor(newVal / inc + 0.5) * inc, min, max)
                SSettings.CurrentValue = newVal
                local pct = (newVal - min) / (max - min)
                tween(fillBar, 0.1, { Size = UDim2.new(pct, 0, 1, 0) })
                valLabel.Text = tostring(newVal) .. (SSettings.Suffix and " " .. SSettings.Suffix or "")
                if fire then
                    local ok, err = pcall(SSettings.Callback, newVal)
                    if not ok then warn("VonHub Slider Error: "..tostring(err)) end
                    if SSettings.Flag then saveCfg() end
                end
            end
            setSliderVal(val, false)

            local draggingSlider = false
            trackBar.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or
                   inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)
            RunService.RenderStepped:Connect(function()
                if draggingSlider then
                    local mx = UserInputService:GetMouseLocation().X
                    local ap = trackBar.AbsolutePosition.X
                    local aw = trackBar.AbsoluteSize.X
                    local pct = math.clamp((mx - ap) / aw, 0, 1)
                    setSliderVal(min + pct * (max - min), true)
                end
            end)

            function SSettings:Set(v) setSliderVal(v, true) end

            if SSettings.Flag then VonHub.Flags[SSettings.Flag] = SSettings end
            return SSettings
        end

