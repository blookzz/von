        -- Per-row accessories: X-circle, Star-circle, Bind-pill
        -- Returns quickItem data for the row
        local function attachRowAccessories(row, label, elemType, quickId)
            local T2 = C()
            local item = {
                id             = quickId,
                label          = label,
                type           = elemType, -- "toggle" or "action"
                on             = false,
                bind           = nil,
                starred        = false,
                mainToggleRef  = nil,
                actionCallback = nil,
            }
            table.insert(quickAccessItems, item)
            quickRegistry[quickId] = item

            -- Positions from right edge of row (right to left):
            -- Control (toggle/diamond) at far right
            -- then bind pill, star, X

            -- X reset circle
            local xcirc = makeCirc(row, UDim2.new(1, -122, 0.5, -9))
            local xLabel = new("TextLabel", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "✕",
                TextColor3 = T2.TextMuted,
                TextSize = 8,
                Font = Enum.Font.GothamBold,
                ZIndex = 7,
            }, xcirc)
            xcirc.MouseButton1Click:Connect(function()
                item.bind = nil
                item.starred = false
                xLabel.TextColor3 = T2.TextMuted
                -- reset bind pill
                local bp = xcirc.Parent:FindFirstChild("BindPill")
                if bp then
                    bp.Text = "[..]"
                    bp.TextColor3 = T2.TextMuted
                end
                -- reset star
                local sc = xcirc.Parent:FindFirstChild("StarCirc")
                if sc then
                    local sl = sc:FindFirstChildWhichIsA("TextLabel")
                    if sl then sl.Text = "☆" sl.TextColor3 = T2.TextDim end
                end
                renderMini()
                showToast("Row reset.")
            end)
            xcirc.Name = "XCirc"

            -- Star circle
            local scirc = makeCirc(row, UDim2.new(1, -100, 0.5, -9))
            scirc.Name = "StarCirc"
            local starLabel = new("TextLabel", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "☆",
                TextColor3 = T2.TextDim,
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                ZIndex = 7,
            }, scirc)
            scirc.MouseButton1Click:Connect(function()
                item.starred = not item.starred
                if item.starred then
                    starLabel.Text = "★"
                    starLabel.TextColor3 = T2.Star
                    tw(scirc, 0.2, { BackgroundColor3 = Color3.fromRGB(30,24,10) })
                    showToast("Pinned to Quick Access!")
                else
                    starLabel.Text = "☆"
                    starLabel.TextColor3 = T2.TextDim
                    tw(scirc, 0.2, { BackgroundColor3 = T2.CircBG })
                end
                renderMini()
            end)

            -- Bind pill
            local bpill = makeBind(row, UDim2.new(1, -66, 0.5, -9))
