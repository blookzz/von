            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 4) }, pill)
            new("UIStroke", { Color = T2.StrokeDim, Thickness = 1, Transparency = 0.4 }, pill)

            pill.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                pill.Text = "···"
                tw(pill, 0.15, { TextColor3 = T2.AccentGlow })
                local conn
                conn = UserInputService.InputBegan:Connect(function(inp, proc)
                    if inp.KeyCode ~= Enum.KeyCode.Unknown and not proc then
                        local kn = inp.KeyCode.Name
                        KSettings.CurrentKeybind = kn
                        pill.Text = "["..kn.."]"
                        pill.Size = UDim2.new(0, math.max(40, #kn*7+10), 0, 20)
                        tw(pill, 0.15, { TextColor3 = T2.TextDim })
                        listening = false
                        conn:Disconnect()
                        if KSettings.Flag then saveCfg() end
                    end
                end)
            end)

            UserInputService.InputBegan:Connect(function(inp, proc)
                if proc or listening then return end
                if KSettings.CurrentKeybind
                and inp.KeyCode == Enum.KeyCode[KSettings.CurrentKeybind] then
                    pcall(KSettings.Callback)
                end
            end)

            function KSettings:Set(key)
                KSettings.CurrentKeybind = key
                pill.Text = "["..key.."]"
            end

            if KSettings.Flag then IceHub.Flags[KSettings.Flag] = KSettings end
            return KSettings
        end

        -- ── ColorPicker ──────────────────────────
        function Tab:CreateColorPicker(CPSettings)
            CPSettings.Type = "ColorPicker"
            local row, lbl = makeRow(CPSettings.Name or "Color Picker")
            local T2 = C()
            local color = CPSettings.Color or Color3.fromRGB(255,255,255)
            local h_, s_, v_ = color:ToHSV()
            local open = false

            local preview = new("Frame", {
                Size = UDim2.new(0, 24, 0, 24),
                Position = UDim2.new(1, -38, 0.5, -12),
                BackgroundColor3 = color,
                BorderSizePixel = 0,
                ZIndex = 6,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 5) }, preview)
            new("UIStroke", { Color = T2.Stroke, Thickness = 1, Transparency = 0.3 }, preview)

            local pickerArea = new("Frame", {
                Size = UDim2.new(1, 0, 0, 0),
                Position = UDim2.new(0, 0, 0, 42),
                BackgroundColor3 = T2.DropBG,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                ZIndex = 5,
            }, row)

            -- Hue slider
            local hueSl = new("Frame", {
                Size = UDim2.new(1, -28, 0, 8),
                Position = UDim2.new(0, 14, 0, 10),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BorderSizePixel = 0,
                ZIndex = 6,
            }, pickerArea)
            new("UICorner", { CornerRadius = UDim.new(0, 4) }, hueSl)
            new("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0,    Color3.fromRGB(255,0,0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
                    ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0,255,255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
                    ColorSequenceKeypoint.new(1,    Color3.fromRGB(255,0,0)),
                }),
                Rotation = 0,
            }, hueSl)
            local hueDot = new("Frame", {
                Size = UDim2.new(0, 10, 0, 10),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(h_, 0, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BorderSizePixel = 0,
                ZIndex = 7,
            }, hueSl)
            new("UICorner", { CornerRadius = UDim.new(1,0) }, hueDot)
            new("UIStroke", { Color = T2.WindowBG, Thickness = 2 }, hueDot)

            -- Hex input
            local hexBox = new("TextBox", {
                Size = UDim2.new(1, -28, 0, 22),
                Position = UDim2.new(0, 14, 0, 26),
                BackgroundColor3 = T2.InputBG,
                BorderSizePixel = 0,
                Text = string.format("#%02X%02X%02X", color.R*255, color.G*255, color.B*255),
                TextColor3 = T2.Text,
                TextSize = 11,
                Font = Enum.Font.GothamMedium,
                PlaceholderText = "#FFFFFF",
                ZIndex = 6,
            }, pickerArea)
            new("UICorner", { CornerRadius = UDim.new(0, 4) }, hexBox)
            new("UIStroke", { Color = T2.StrokeDim, Thickness = 1, Transparency = 0.4 }, hexBox)
            new("UIPadding", { PaddingLeft = UDim.new(0, 6) }, hexBox)

            local pickerH = 60

            local interact = new("TextButton", {
                Size = UDim2.new(0, 32, 0, 32),
                Position = UDim2.new(1, -38, 0.5, -16),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 7,
            }, row)

            local function updateColor()
                local nc = Color3.fromHSV(h_, s_, v_)
                preview.BackgroundColor3 = nc
                hexBox.Text = string.format("#%02X%02X%02X", nc.R*255, nc.G*255, nc.B*255)
                CPSettings.Color = nc
                pcall(CPSettings.Callback, nc)
            end

            local draggingHue = false
            hueSl.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then draggingHue = true end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then draggingHue = false end
            end)
            RunService.RenderStepped:Connect(function()
                if draggingHue then
                    local mx = UserInputService:GetMouseLocation().X
                    local ap = hueSl.AbsolutePosition.X
                    local aw = hueSl.AbsoluteSize.X
                    h_ = math.clamp((mx - ap)/aw, 0, 1)
                    hueDot.Position = UDim2.new(h_, 0, 0.5, 0)
                    updateColor()
                end
            end)

            hexBox.FocusLost:Connect(function()
                local hex = hexBox.Text:gsub("#","")
                local r, g, b = hex:match("(%w%w)(%w%w)(%w%w)")
                if r then
                    local nc = Color3.fromRGB(tonumber(r,16), tonumber(g,16), tonumber(b,16))
                    h_, s_, v_ = nc:ToHSV()
                    updateColor()
                end
            end)

            interact.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    row.Size = UDim2.new(1, 0, 0, 42 + pickerH)
                    tw(pickerArea, 0.22, { Size = UDim2.new(1, 0, 0, pickerH) })
                else
                    row.Size = UDim2.new(1, 0, 0, 42)
                    tw(pickerArea, 0.22, { Size = UDim2.new(1, 0, 0, 0) })
                end
            end)

            function CPSettings:Set(c)
                CPSettings.Color = c
                h_, s_, v_ = c:ToHSV()
                preview.BackgroundColor3 = c
                hexBox.Text = string.format("#%02X%02X%02X", c.R*255, c.G*255, c.B*255)
            end

            if CPSettings.Flag then IceHub.Flags[CPSettings.Flag] = CPSettings end
            return CPSettings
        end

        -- ── Multi-Dropdown ────────────────────────
        -- (alias for Dropdown with MultipleOptions = true)
        function Tab:CreateMultiDropdown(DSettings)
            DSettings.MultipleOptions = true
            return self:CreateDropdown(DSettings)
        end

        return Tab
    end -- CreateTab

    -- ── Key System ────────────────────────────────
    if Settings.KeySystem and Settings.KeySettings then
        local KS = Settings.KeySettings
        local validKeys = type(KS.Key) == "string" and {KS.Key} or (KS.Key or {})
        local T2 = C()

        local keyGui = new("ScreenGui", {
            Name = "IceHubKey",
            ResetOnSpawn = false,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
            DisplayOrder = 150,
        })
        if gethui then keyGui.Parent = gethui()
        elseif not RunService:IsStudio() then keyGui.Parent = CoreGui
        else keyGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui") end

        local keyFrame = new("Frame", {
            Size = UDim2.new(0, 420, 0, 168),
            Position = UDim2.new(0.5, -210, 0.5, -84),
            BackgroundColor3 = T2.WindowBG,
            BorderSizePixel = 0,
            ZIndex = 10,
        }, keyGui)
        new("UICorner", { CornerRadius = UDim.new(0, 10) }, keyFrame)
        new("UIStroke", { Color = T2.Stroke, Thickness = 1, Transparency = 0.4 }, keyFrame)
        new("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(20,24,40)),
                ColorSequenceKeypoint.new(1, T2.WindowBG),
            }),
            Rotation = 160,
        }, keyFrame)

        -- Key system glow dot + title
        local kdot = new("Frame", {
            Size = UDim2.new(0, 9, 0, 9),
            Position = UDim2.new(0, 14, 0, 18),
            BackgroundColor3 = T2.AccentGlow,
            BorderSizePixel = 0,
            ZIndex = 11,
        }, keyFrame)
        new("UICorner", { CornerRadius = UDim.new(1,0) }, kdot)

        new("TextLabel", {
            Size = UDim2.new(1, -38, 0, 30),
            Position = UDim2.new(0, 30, 0, 10),
            BackgroundTransparency = 1,
            Text = KS.Title or "Key System",
            TextColor3 = T2.Text,
            TextSize = 15,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 11,
        }, keyFrame)

        new("TextLabel", {
            Size = UDim2.new(1, -28, 0, 20),
            Position = UDim2.new(0, 14, 0, 44),
            BackgroundTransparency = 1,
            Text = KS.Note or "Enter your access key below",
            TextColor3 = T2.TextDim,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 11,
        }, keyFrame)

        local keyBox = new("TextBox", {
            Size = UDim2.new(1, -28, 0, 32),
            Position = UDim2.new(0, 14, 0, 70),
            BackgroundColor3 = T2.InputBG,
            BorderSizePixel = 0,
            PlaceholderText = "Enter key...",
            PlaceholderColor3 = T2.TextMuted,
            TextColor3 = T2.Text,
            TextSize = 13,
            Font = Enum.Font.Gotham,
            ClearTextOnFocus = false,
            ZIndex = 11,
        }, keyFrame)
        new("UICorner", { CornerRadius = UDim.new(0, 6) }, keyBox)
        new("UIStroke", { Color = T2.StrokeDim, Thickness = 1, Transparency = 0.3 }, keyBox)
        new("UIPadding", { PaddingLeft = UDim.new(0, 8) }, keyBox)

        local submitBtn = new("TextButton", {
            Size = UDim2.new(1, -28, 0, 30),
            Position = UDim2.new(0, 14, 0, 112),
            BackgroundColor3 = T2.Accent,
            BorderSizePixel = 0,
            Text = "Submit",
            TextColor3 = T2.White,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            ZIndex = 11,
        }, keyFrame)
        new("UICorner", { CornerRadius = UDim.new(0, 6) }, submitBtn)

        local passed = false
        if isfile and isfile("IceHub/keys/"..(KS.FileName or "key")..".txt") then
            local savedKey = readfile("IceHub/keys/"..(KS.FileName or "key")..".txt")
            for _, k in ipairs(validKeys) do
                if savedKey == k then passed = true break end
            end
        end

        if not passed then
            MainFrame.Visible = false
            if MiniGui then MiniGui.Visible = false end
            submitBtn.MouseButton1Click:Connect(function()
                local ent = keyBox.Text
                local found = false
                for _, k in ipairs(validKeys) do
                    if ent == k then found = true break end
                end
                if found then
                    if KS.SaveKey and writefile then
                        if not isfolder("IceHub/keys") then makefolder("IceHub/keys") end
                        writefile("IceHub/keys/"..(KS.FileName or "key")..".txt", ent)
                    end
                    keyGui:Destroy()
                    MainFrame.Visible = true
                    if MiniGui then MiniGui.Visible = true end
                else
                    tw(keyFrame, 0.1, { BackgroundColor3 = Color3.fromRGB(60, 16, 14) })
                    task.delay(0.3, function()
                        tw(keyFrame, 0.3, { BackgroundColor3 = T2.WindowBG })
                    end)
                end
            end)
        else
            keyGui:Destroy()
        end
    end

    -- Animate window open
    MainFrame.BackgroundTransparency = 1
    MainFrame.Size = UDim2.new(0, 420, 0, 0)
    tw(MainFrame, 0.45, { BackgroundTransparency = 0, Size = UDim2.new(0, 620, 0, 400) })

    return Window
end -- CreateWindow

-- ─────────────────────────────────────────────────
-- LoadConfiguration
-- ─────────────────────────────────────────────────
function IceHub:LoadConfiguration()
    if not (isfile and readfile) then return end
    local loaded = false
    for flag, elem in pairs(self.Flags) do
        local path = "IceHub/config.json"
        if isfile(path) then
            local ok, data = pcall(function()
                return HttpService:JSONDecode(readfile(path))
            end)
            if ok and data and data[flag] ~= nil then
                pcall(elem.Set, elem, data[flag])
                loaded = true
            end
        end
    end
    if loaded then
        self:Notify({ Title = "Ice Hub", Content = "Config loaded.", Duration = 2 })
    end
end

return IceHub
