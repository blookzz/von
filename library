        -- ── Dropdown ─────────────────────────────
        function Tab:CreateDropdown(DSettings)
            DSettings.Type = "Dropdown"
            if type(DSettings.CurrentOption) == "string" then
                DSettings.CurrentOption = { DSettings.CurrentOption }
            end
            DSettings.CurrentOption = DSettings.CurrentOption or {}

            rowOrder = rowOrder + 1
            local T2 = C()
            local rowH = 42
            local isOpen = false

            local container = new("Frame", {
                Name = "Drop_"..DSettings.Name,
                Size = UDim2.new(1, 0, 0, rowH),
                BackgroundColor3 = T2.ElementBG,
                BorderSizePixel = 0,
                LayoutOrder = rowOrder,
                ClipsDescendants = true,
                ZIndex = 4,
            }, page)
            new("Frame", {
                Size = UDim2.new(1, 0, 0, 1),
                Position = UDim2.new(0, 0, 0, rowH - 1),
                BackgroundColor3 = T2.StrokeDim,
                BackgroundTransparency = 0.88,
                BorderSizePixel = 0,
                ZIndex = 4,
            }, container)
            new("TextLabel", {
                Size = UDim2.new(0.55, 0, 0, rowH),
                Position = UDim2.new(0, 14, 0, 0),
                BackgroundTransparency = 1,
                Text = DSettings.Name or "Dropdown",
                TextColor3 = T2.Text,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
            }, container)
            local selText = new("TextLabel", {
                Size = UDim2.new(0.4, -24, 0, rowH),
                Position = UDim2.new(0.6, -10, 0, 0),
                BackgroundTransparency = 1,
                Text = #DSettings.CurrentOption > 0 and DSettings.CurrentOption[1] or "None",
                TextColor3 = T2.AccentGlow,
                TextSize = 12,
                Font = Enum.Font.GothamMedium,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
            }, container)
            local arrow = new("TextLabel", {
                Size = UDim2.new(0, 16, 0, rowH),
                Position = UDim2.new(1, -22, 0, 0),
                BackgroundTransparency = 1,
                Text = "▾",
                TextColor3 = T2.TextDim,
                TextSize = 12,
                Font = Enum.Font.GothamBold,
                ZIndex = 5,
            }, container)
            local optList = new("Frame", {
                Size = UDim2.new(1, 0, 0, 0),
                Position = UDim2.new(0, 0, 0, rowH),
                BackgroundColor3 = T2.DropBG,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, container)
            new("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 0),
            }, optList)

            local function buildOptions()
                for _, c in ipairs(optList:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                for i, opt in ipairs(DSettings.Options or {}) do
                    local sel = table.find(DSettings.CurrentOption, opt) ~= nil
                    local or_ = new("Frame", {
                        Size = UDim2.new(1, 0, 0, 34),
                        BackgroundColor3 = sel and T2.DropSel or T2.DropBG,
                        BorderSizePixel = 0,
                        LayoutOrder = i,
                        ZIndex = 6,
                    }, optList)
                    -- Check dot for selected
                    if sel then
                        local ckdot = new("Frame", {
                            Size = UDim2.new(0, 5, 0, 5),
                            Position = UDim2.new(0, 7, 0.5, -2.5),
                            BackgroundColor3 = T2.AccentGlow,
                            BorderSizePixel = 0,
                            ZIndex = 7,
                        }, or_)
                        new("UICorner", { CornerRadius = UDim.new(1,0) }, ckdot)
                    end
                    new("TextLabel", {
                        Size = UDim2.new(1, -20, 1, 0),
                        Position = UDim2.new(0, 16, 0, 0),
                        BackgroundTransparency = 1,
                        Text = opt,
                        TextColor3 = sel and T2.AccentGlow or T2.TextDim,
                        TextSize = 12,
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 7,
                    }, or_)
                    local ib = new("TextButton", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text = "",
                        ZIndex = 8,
                    }, or_)
                    ib.MouseButton1Click:Connect(function()
                        if not DSettings.MultipleOptions then
                            DSettings.CurrentOption = { opt }
                            selText.Text = opt
                            isOpen = false
                            tween(container, 0.22, { Size = UDim2.new(1, 0, 0, rowH) })
                            arrow.Text = "▾"
                        else
                            local idx = table.find(DSettings.CurrentOption, opt)
                            if idx then table.remove(DSettings.CurrentOption, idx)
                            else table.insert(DSettings.CurrentOption, opt) end
                            selText.Text = #DSettings.CurrentOption == 0 and "None"
                                or (#DSettings.CurrentOption == 1 and DSettings.CurrentOption[1] or "Various")
                        end
                        buildOptions()
                        pcall(DSettings.Callback, DSettings.CurrentOption)
                        if DSettings.Flag then saveCfg() end
                    end)
                    or_.MouseEnter:Connect(function() tw(or_, 0.12, { BackgroundColor3 = T2.ElementHov }) end)
                    or_.MouseLeave:Connect(function()
                        tw(or_, 0.12, { BackgroundColor3 = table.find(DSettings.CurrentOption, opt) and T2.DropSel or T2.DropBG })
                    end)
                end
                local lh = #(DSettings.Options or {}) * 34
                optList.Size = UDim2.new(1, 0, 0, lh)
            end
            buildOptions()

            local interact = new("TextButton", {
                Size = UDim2.new(1, 0, 0, rowH),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 9,
            }, container)
            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    local lh = #(DSettings.Options or {}) * 34
                    tw(container, 0.22, { Size = UDim2.new(1, 0, 0, rowH + lh) })
                    arrow.Text = "▴"
                else
                    tw(container, 0.22, { Size = UDim2.new(1, 0, 0, rowH) })
                    arrow.Text = "▾"
                end
            end)
            container.MouseEnter:Connect(function() tw(container, 0.18, { BackgroundColor3 = T2.ElementHov }) end)
            container.MouseLeave:Connect(function() tw(container, 0.18, { BackgroundColor3 = T2.ElementBG }) end)

            function DSettings:Set(opt)
                if type(opt) == "string" then opt = { opt } end
                DSettings.CurrentOption = opt
                selText.Text = #opt == 0 and "None" or (#opt == 1 and opt[1] or "Various")
                buildOptions()
                pcall(DSettings.Callback, DSettings.CurrentOption)
            end
            function DSettings:Refresh(newOpts)
                DSettings.Options = newOpts
                buildOptions()
            end

            if DSettings.Flag then IceHub.Flags[DSettings.Flag] = DSettings end
            return DSettings
        end

