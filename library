        -- ── Toggle ───────────────────────────────
        function Tab:CreateToggle(TSettings)
            TSettings.Type = "Toggle"
            TSettings.CurrentValue = TSettings.CurrentValue or false

            local row, lbl = makeRow(TSettings.Name or "Toggle")
            local T2 = C()
            local qid = TSettings.Flag or TSettings.Name or ("tog_"..rowOrder)
            local item = attachRowAccessories(row, TSettings.Name or "Toggle", "toggle", qid)
            item.on = TSettings.CurrentValue

            -- Toggle track
            local trackW, trackH = 40, 20
            local track = new("Frame", {
                Size = UDim2.new(0, trackW, 0, trackH),
                Position = UDim2.new(1, -(trackW + 12), 0.5, -trackH/2),
                BackgroundColor3 = TSettings.CurrentValue and T2.ToggleOn or T2.ToggleOff,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 10) }, track)
            new("UIStroke", { Color = T2.StrokeDim, Thickness = 1, Transparency = 0.35 }, track)
            new("UIGradient", {
                Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 0),
                }),
                -- subtle inner shadow via gradient
            }, track)

            -- Diamond knob
            local ks = 11
            local knob = new("Frame", {
                Size = UDim2.new(0, ks, 0, ks),
                Position = TSettings.CurrentValue
                    and UDim2.new(0, trackW - ks - 5, 0.5, -ks/2)
                    or  UDim2.new(0, 5, 0.5, -ks/2),
                Rotation = 45,
                BackgroundColor3 = TSettings.CurrentValue and T2.KnobOn or T2.KnobOff,
                BorderSizePixel = 0,
                ZIndex = 6,
            }, track)
            new("UICorner", { CornerRadius = UDim.new(0, 2) }, knob)
            new("UIStroke", { Color = T2.Stroke, Thickness = 1, Transparency = 0.45 }, knob)
            new("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, T2.KnobOn),
                    ColorSequenceKeypoint.new(1, T2.KnobOff),
                }),
                Rotation = 145,
            }, knob)

            local function applyToggle(val, fireCallback)
                TSettings.CurrentValue = val
                item.on = val
                if val then
                    tw(track, 0.25, { BackgroundColor3 = T2.ToggleOn })
                    tw(knob, 0.22, {
                        Position = UDim2.new(0, trackW - ks - 5, 0.5, -ks/2),
                        BackgroundColor3 = T2.KnobOn,
                    })
                else
                    tw(track, 0.25, { BackgroundColor3 = T2.ToggleOff })
                    tw(knob, 0.22, {
                        Position = UDim2.new(0, 5, 0.5, -ks/2),
                        BackgroundColor3 = T2.KnobOff,
                    })
                end
                if fireCallback and TSettings.Callback then
                    pcall(TSettings.Callback, val)
                end
                if TSettings.Flag then saveCfg() end
                renderMini()
            end

            -- expose to mini panel
            item.mainToggleRef = function(v) applyToggle(v, true) end

            local click = new("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 7,
            }, row)
            click.MouseButton1Click:Connect(function()
                applyToggle(not TSettings.CurrentValue, true)
            end)

            function TSettings:Set(v) applyToggle(v, true) end

            if TSettings.Flag then IceHub.Flags[TSettings.Flag] = TSettings end
            return TSettings
        end

        -- ── Slider ───────────────────────────────
        function Tab:CreateSlider(SSettings)
            SSettings.Type = "Slider"
            local row, lbl = makeRow(SSettings.Name or "Slider")
            row.Size = UDim2.new(1, 0, 0, 56)
            local T2 = C()

            local min_ = SSettings.Range[1]
            local max_ = SSettings.Range[2]
            local inc  = SSettings.Increment or 1
            local val  = math.clamp(SSettings.CurrentValue or min_, min_, max_)

            local valLabel = new("TextLabel", {
                Size = UDim2.new(0, 60, 0, 14),
                Position = UDim2.new(1, -74, 0, 12),
                BackgroundTransparency = 1,
                Text = tostring(val)..(SSettings.Suffix and " "..SSettings.Suffix or ""),
                TextColor3 = T2.AccentGlow,
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
            }, row)

            local trackBar = new("Frame", {
                Size = UDim2.new(1, -28, 0, 5),
                Position = UDim2.new(0, 14, 0, 36),
                BackgroundColor3 = T2.SliderBG,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 3) }, trackBar)
            new("UIStroke", { Color = T2.StrokeDim, Thickness = 1, Transparency = 0.4 }, trackBar)

            local fillBar = new("Frame", {
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = T2.SliderFill,
                BorderSizePixel = 0,
                ZIndex = 6,
            }, trackBar)
            new("UICorner", { CornerRadius = UDim.new(0, 3) }, fillBar)
            -- glow gradient on fill
            new("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, T2.AccentGlow),
                    ColorSequenceKeypoint.new(1, T2.SliderFill),
                }),
                Rotation = 0,
            }, fillBar)

            -- Thumb dot on slider
            local thumb = new("Frame", {
                Size = UDim2.new(0, 7, 0, 7),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(0, 0, 0.5, 0),
                BackgroundColor3 = T2.White,
                BorderSizePixel = 0,
                ZIndex = 7,
            }, trackBar)
            new("UICorner", { CornerRadius = UDim.new(1, 0) }, thumb)

            local function setSliderVal(newVal, fire)
                newVal = math.clamp(math.floor(newVal/inc + 0.5)*inc, min_, max_)
                SSettings.CurrentValue = newVal
                local pct = (newVal - min_) / (max_ - min_)
                tw(fillBar, 0.08, { Size = UDim2.new(pct, 0, 1, 0) })
                thumb.Position = UDim2.new(pct, 0, 0.5, 0)
                valLabel.Text = tostring(newVal)..(SSettings.Suffix and " "..SSettings.Suffix or "")
                if fire then
                    pcall(SSettings.Callback, newVal)
                    if SSettings.Flag then saveCfg() end
                end
            end
            setSliderVal(val, false)

            local draggingSlider = false
            trackBar.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1
                or inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)
            RunService.RenderStepped:Connect(function()
                if draggingSlider then
                    local mx = UserInputService:GetMouseLocation().X
                    local ap = trackBar.AbsolutePosition.X
                    local aw = trackBar.AbsoluteSize.X
                    local pct = math.clamp((mx - ap)/aw, 0, 1)
                    setSliderVal(min_ + pct*(max_ - min_), true)
                end
            end)

            function SSettings:Set(v) setSliderVal(v, true) end

            if SSettings.Flag then IceHub.Flags[SSettings.Flag] = SSettings end
            return SSettings
        end

