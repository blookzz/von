-- ──────────────────────────────────────────────────
-- Instance Factory
-- ──────────────────────────────────────────────────
local function new(class, props, parent)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do obj[k] = v end
    if parent then obj.Parent = parent end
    return obj
end

-- ──────────────────────────────────────────────────
-- Gradient Helper (for separator lines)
-- ──────────────────────────────────────────────────
local function addGradient(frame, horizontal)
    local g = new("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(0.2, C.Stroke),
            ColorSequenceKeypoint.new(0.5, C.AccentGlow),
            ColorSequenceKeypoint.new(0.8, C.Stroke),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(0,0,0)),
        }),
        Rotation = horizontal and 0 or 90,
    }, frame)
    return g
end

-- ──────────────────────────────────────────────────
-- Notification System
-- ──────────────────────────────────────────────────
local NotifHolder = nil

local function ensureNotifHolder()
    if NotifHolder and NotifHolder.Parent then return end
    NotifHolder = new("ScreenGui", {
        Name = "VonHubNotifications",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 200,
    })
    if gethui then
        NotifHolder.Parent = gethui()
    elseif not RunService:IsStudio() then
        NotifHolder.Parent = CoreGui
    else
        NotifHolder.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
    end

    new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        Padding = UDim.new(0, 6),
    }, NotifHolder)

    new("UIPadding", {
        PaddingBottom = UDim.new(0, 16),
        PaddingRight  = UDim.new(0, 16),
    }, NotifHolder)
end

function VonHub:Notify(data)
    ensureNotifHolder()
    task.spawn(function()
        local notif = new("Frame", {
            Name            = "VonNotif",
            Size            = UDim2.new(0, 280, 0, 0),
            BackgroundColor3 = C.BG2,
            BackgroundTransparency = 0,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = 50,
        }, NotifHolder)

        new("UICorner", { CornerRadius = UDim.new(0, 7) }, notif)
        new("UIStroke", { Color = C.Stroke, Thickness = 1, Transparency = 0.4 }, notif)

        -- Blue dot
        local dot = new("Frame", {
            Size = UDim2.new(0, 8, 0, 8),
            Position = UDim2.new(0, 12, 0, 14),
            BackgroundColor3 = C.AccentGlow,
            BorderSizePixel = 0,
            ZIndex = 51,
        }, notif)
        new("UICorner", { CornerRadius = UDim.new(1, 0) }, dot)

        local title = new("TextLabel", {
            Size = UDim2.new(1, -36, 0, 18),
            Position = UDim2.new(0, 28, 0, 8),
            BackgroundTransparency = 1,
            Text = data.Title or "Von Hub",
            TextColor3 = C.Text,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 51,
        }, notif)

        local content = new("TextLabel", {
            Size = UDim2.new(1, -20, 0, 0),
            Position = UDim2.new(0, 12, 0, 30),
            BackgroundTransparency = 1,
            Text = data.Content or "",
            TextColor3 = C.TextDim,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 51,
        }, notif)

        task.wait()
        local bounds = content.TextBounds.Y
        local totalH = math.max(bounds + 42, 50)
        content.Size = UDim2.new(1, -20, 0, bounds + 4)

        tween(notif, 0.4, { Size = UDim2.new(0, 280, 0, totalH) })
        task.wait(data.Duration or 4)
        tween(notif, 0.3, { BackgroundTransparency = 1, Size = UDim2.new(0, 240, 0, 0) })
        task.wait(0.35)
        notif:Destroy()
    end)
end

-- ──────────────────────────────────────────────────
-- CreateWindow
-- ──────────────────────────────────────────────────
function VonHub:CreateWindow(Settings)
    Settings = Settings or {}
    local WindowName    = Settings.Name or "Von Hub"
    local WindowVersion = Settings.Version or "v1.0"
    local Theme         = Settings.Theme  -- future use
    local configEnabled = Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled or false
    local configFolder  = Settings.ConfigurationSaving and Settings.ConfigurationSaving.FolderName or "VonHub"
    local configFile    = Settings.ConfigurationSaving and Settings.ConfigurationSaving.FileName or "config"

    -- ── Root ScreenGui ───────────────────────────
    local ScreenGui = new("ScreenGui", {
        Name = "VonHubUI",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 100,
    })
    if gethui then
        ScreenGui.Parent = gethui()
    elseif not RunService:IsStudio() and CoreGui then
        ScreenGui.Parent = CoreGui
    else
        ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
    end

    -- ── Main Window Frame ────────────────────────
    local MainFrame = new("Frame", {
        Name             = "MainFrame",
        Size             = UDim2.new(0, 620, 0, 400),
        Position         = UDim2.new(0.5, -310, 0.5, -200),
        BackgroundColor3 = C.BG,
        BorderSizePixel  = 0,
        ClipsDescendants = true,
    }, ScreenGui)
    new("UICorner", { CornerRadius = UDim.new(0, 10) }, MainFrame)
    new("UIStroke", { Color = C.Stroke, Thickness = 1, Transparency = 0.6 }, MainFrame)

    -- outer glow shadow frame
    local Shadow = new("ImageLabel", {
        Name = "Shadow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Size = UDim2.new(1, 60, 1, 60),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6015897843",
        ImageColor3 = C.Accent,
        ImageTransparency = 0.6,
        ZIndex = 0,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
    }, MainFrame)

    -- ── Titlebar ─────────────────────────────────
    local Titlebar = new("Frame", {
        Name             = "Titlebar",
        Size             = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = C.Topbar,
        BackgroundTransparency = 0.6,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }, MainFrame)

    -- Dot (glowing blue)
    local TitleDot = new("Frame", {
        Size = UDim2.new(0, 9, 0, 9),
        Position = UDim2.new(0, 14, 0.5, -4.5),
        BackgroundColor3 = C.AccentGlow,
        BorderSizePixel = 0,
        ZIndex = 4,
    }, Titlebar)
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, TitleDot)

    local TitleLabel = new("TextLabel", {
        Size = UDim2.new(0.7, 0, 1, 0),
        Position = UDim2.new(0, 30, 0, 0),
        BackgroundTransparency = 1,
        Text = WindowName,
        TextColor3 = C.Text,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
    }, Titlebar)

    local VerLabel = new("TextLabel", {
        Size = UDim2.new(0, 60, 1, 0),
        Position = UDim2.new(0, 30 + TitleLabel.TextBounds.X + 4, 0, 0),
        BackgroundTransparency = 1,
        Text = WindowVersion,
        TextColor3 = C.TextMuted,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 4,
    }, Titlebar)
    -- Update version label position after title renders
    task.defer(function()
        VerLabel.Position = UDim2.new(0, 30 + TitleLabel.TextBounds.X + 6, 0, 0)
    end)

    -- Close / Minimize buttons
    local CloseBtn = new("TextButton", {
        Size = UDim2.new(0, 22, 0, 22),
        Position = UDim2.new(1, -12, 0.5, -11),
        AnchorPoint = Vector2.new(1, 0),
        BackgroundColor3 = Color3.fromRGB(192, 57, 43),
        BorderSizePixel = 0,
        Text = "✕",
        TextColor3 = C.White,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        ZIndex = 5,
    }, Titlebar)
    new("UICorner", { CornerRadius = UDim.new(0, 5) }, CloseBtn)

    local MinBtn = new("TextButton", {
        Size = UDim2.new(0, 22, 0, 22),
        Position = UDim2.new(1, -38, 0.5, -11),
        AnchorPoint = Vector2.new(1, 0),
        BackgroundColor3 = C.ElementBG,
        BorderSizePixel = 0,
        Text = "−",
        TextColor3 = C.TextDim,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        ZIndex = 5,
    }, Titlebar)
    new("UICorner", { CornerRadius = UDim.new(0, 5) }, MinBtn)
    new("UIStroke", { Color = C.StrokeDim, Thickness = 1, Transparency = 0.5 }, MinBtn)

    -- Separator line under titlebar
    local TitleSep = new("Frame", {
        Name = "TitleSep",
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 0, 38),
        BackgroundColor3 = C.SepLine,
        BorderSizePixel = 0,
        ZIndex = 3,
    }, MainFrame)
    addGradient(TitleSep, true)

    -- ── Body ─────────────────────────────────────
    local Body = new("Frame", {
        Name = "Body",
        Size = UDim2.new(1, 0, 1, -39),
        Position = UDim2.new(0, 0, 0, 39),
        BackgroundTransparency = 1,
        ZIndex = 2,
    }, MainFrame)

    -- ── Sidebar ───────────────────────────────────
    local Sidebar = new("Frame", {
        Name = "Sidebar",
        Size = UDim2.new(0, 158, 1, 0),
        BackgroundColor3 = C.Sidebar,
        BackgroundTransparency = 0.25,
        BorderSizePixel = 0,
        ZIndex = 3,
    }, Body)

    -- Vertical separator line right of sidebar
    local SidebarSep = new("Frame", {
        Name = "SidebarSep",
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        AnchorPoint = Vector2.new(1, 0),
        BackgroundColor3 = C.SepLine,
        BorderSizePixel = 0,
        ZIndex = 4,
    }, Sidebar)
    addGradient(SidebarSep, false)

    local TabListLayout = new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 0),
    }, Sidebar)

    new("UIPadding", { PaddingTop = UDim.new(0, 8) }, Sidebar)

    -- ── Panel (content area) ──────────────────────
    local Panel = new("ScrollingFrame", {
        Name = "Panel",
        Size = UDim2.new(1, -158, 1, 0),
        Position = UDim2.new(0, 158, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = C.Stroke,
        ScrollBarImageTransparency = 0.5,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ZIndex = 2,
    }, Body)

    new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 0),
    }, Panel)

    -- ── Dragging ──────────────────────────────────
    local dragging, dragStart, startPos = false, nil, nil
    Titlebar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = inp.Position
            startPos  = MainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    -- ── Minimise ──────────────────────────────────
    local minimised = false
    MinBtn.MouseButton1Click:Connect(function()
        minimised = not minimised
        if minimised then
            tween(MainFrame, 0.35, { Size = UDim2.new(0, 620, 0, 38) })
        else
            tween(MainFrame, 0.35, { Size = UDim2.new(0, 620, 0, 400) })
        end
    end)

    -- ── Close ─────────────────────────────────────
    CloseBtn.MouseButton1Click:Connect(function()
        tween(MainFrame, 0.3, { BackgroundTransparency = 1 })
        task.wait(0.32)
        ScreenGui:Destroy()
    end)
    CloseBtn.MouseEnter:Connect(function() tween(CloseBtn, 0.15, { BackgroundColor3 = Color3.fromRGB(231, 76, 60) }) end)
    CloseBtn.MouseLeave:Connect(function() tween(CloseBtn, 0.15, { BackgroundColor3 = C.Red }) end)

    -- ── Toggle UI Hotkey ──────────────────────────
    local hidden = false
    if Settings.ToggleKey then
        UserInputService.InputBegan:Connect(function(inp, proc)
            if proc then return end
            if inp.KeyCode == Enum.KeyCode[tostring(Settings.ToggleKey)] then
                hidden = not hidden
                MainFrame.Visible = not hidden
            end
        end)
    end

    -- ── Tab Management ────────────────────────────
    local tabs = {}
    local firstTab = true

    -- Save / Load helpers
    local function saveCfg()
        if not configEnabled then return end
        local data = {}
        for flag, elem in pairs(VonHub.Flags) do
            if elem.Type == "Toggle"   then data[flag] = elem.CurrentValue
            elseif elem.Type == "Slider"   then data[flag] = elem.CurrentValue
            elseif elem.Type == "Dropdown" then data[flag] = elem.CurrentOption
            elseif elem.Type == "Keybind"  then data[flag] = elem.CurrentKeybind
            elseif elem.Type == "Input"    then data[flag] = elem.CurrentValue
            end
        end
        if writefile then
            if not isfolder(configFolder) then makefolder(configFolder) end
            writefile(configFolder .. "/" .. configFile .. ".json", HttpService:JSONEncode(data))
        end
    end

    -- Window API
    local Window = {}

    function Window:Notify(data) VonHub:Notify(data) end

    -- ──────────────────────────────────────────────
    -- CreateTab
    -- ──────────────────────────────────────────────
    function Window:CreateTab(Name, Icon)
        -- Sidebar button
        local tabBtn = new("TextButton", {
            Name = Name,
            Size = UDim2.new(1, -10, 0, 34),
            BackgroundTransparency = 1,
            Text = "",
            BorderSizePixel = 0,
            ZIndex = 4,
            LayoutOrder = #tabs + 1,
        }, Sidebar)

        local leftAccent = new("Frame", {
            Size = UDim2.new(0, 2.5, 1, -8),
            Position = UDim2.new(0, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5),
            BackgroundColor3 = C.AccentGlow,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ZIndex = 5,
        }, tabBtn)
        new("UICorner", { CornerRadius = UDim.new(0, 2) }, leftAccent)

        local tabBG = new("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = C.Accent,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ZIndex = 4,
        }, tabBtn)
        new("UICorner", { CornerRadius = UDim.new(0, 7) }, tabBG)

        local tabLabel = new("TextLabel", {
            Size = UDim2.new(1, -18, 1, 0),
            Position = UDim2.new(0, 18, 0, 0),
            BackgroundTransparency = 1,
            Text = Name,
            TextColor3 = C.TextDim,
            TextSize = 13,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 5,
        }, tabBtn)

        -- Content page
        local page = new("Frame", {
            Name = Name .. "Page",
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Visible = false,
            ZIndex = 2,
        }, Panel)
        new("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 0) }, page)

        local function selectTab()
            -- Deselect all
            for _, t in ipairs(tabs) do
                tween(t.btn, 0.2, { BackgroundTransparency = 1 })
                tween(t.label, 0.2, { TextColor3 = C.TextDim })
                t.accent.BackgroundTransparency = 1
                t.label.Font = Enum.Font.Gotham
                t.page.Visible = false
            end
            -- Select this
            tween(tabBG, 0.25, { BackgroundTransparency = 0.7 })
            tween(tabLabel, 0.2, { TextColor3 = C.White })
            leftAccent.BackgroundTransparency = 0
            tabLabel.Font = Enum.Font.GothamBold
            page.Visible = true
        end

        tabBtn.MouseButton1Click:Connect(selectTab)
        tabBtn.MouseEnter:Connect(function()
            if tabLabel.Font ~= Enum.Font.GothamBold then
                tween(tabLabel, 0.15, { TextColor3 = Color3.fromRGB(140, 150, 190) })
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if tabLabel.Font ~= Enum.Font.GothamBold then
                tween(tabLabel, 0.15, { TextColor3 = C.TextDim })
            end
        end)

        local tabData = { btn = tabBG, label = tabLabel, accent = leftAccent, page = page }
        table.insert(tabs, tabData)

        if firstTab then
            firstTab = false
            task.defer(selectTab)
        end

        -- ─────────────────────────────────────────
        -- Row builder helper
        -- ─────────────────────────────────────────
        local function makeRow(labelText, order)
            local row = new("Frame", {
                Name = labelText,
                Size = UDim2.new(1, 0, 0, 42),
                BackgroundColor3 = C.ElementBG,
                BackgroundTransparency = 0,
                BorderSizePixel = 0,
                LayoutOrder = order or 0,
                ZIndex = 3,
            }, page)

            local sep = new("Frame", {
                Size = UDim2.new(1, 0, 0, 1),
                Position = UDim2.new(0, 0, 1, -1),
                BackgroundColor3 = C.StrokeDim,
                BackgroundTransparency = 0.7,
                BorderSizePixel = 0,
                ZIndex = 3,
            }, row)

            local lbl = new("TextLabel", {
                Size = UDim2.new(0.55, 0, 1, 0),
                Position = UDim2.new(0, 14, 0, 0),
                BackgroundTransparency = 1,
                Text = labelText,
                TextColor3 = C.Text,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 4,
            }, row)

            row.MouseEnter:Connect(function() tween(row, 0.2, { BackgroundColor3 = C.ElementHov }) end)
            row.MouseLeave:Connect(function() tween(row, 0.2, { BackgroundColor3 = C.ElementBG }) end)

            return row, lbl
        end

        -- ─────────────────────────────────────────
        -- Tab API
        -- ─────────────────────────────────────────
        local Tab = {}
        local rowCount = 0

        -- ── Section ──────────────────────────────
        function Tab:CreateSection(SectionName)
            local secFrame = new("Frame", {
                Name = "Section_" .. SectionName,
                Size = UDim2.new(1, 0, 0, 28),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                LayoutOrder = rowCount,
                ZIndex = 3,
            }, page)
            rowCount += 1

            new("Frame", {
                Size = UDim2.new(1, -28, 0, 1),
                Position = UDim2.new(0, 14, 0.5, 0),
                BackgroundColor3 = C.Section,
                BackgroundTransparency = 0.6,
                BorderSizePixel = 0,
                ZIndex = 3,
            }, secFrame)

            new("TextLabel", {
                Size = UDim2.new(1, -28, 1, 0),
                Position = UDim2.new(0, 14, 0, 0),
                BackgroundTransparency = 1,
                Text = SectionName,
                TextColor3 = C.Section,
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 4,
            }, secFrame)

            local SectionValue = {}
            function SectionValue:Set(n)
                secFrame:FindFirstChildWhichIsA("TextLabel").Text = n
            end
            return SectionValue
        end

        -- ── Divider ───────────────────────────────
        function Tab:CreateDivider()
            local div = new("Frame", {
                Size = UDim2.new(1, 0, 0, 1),
                BackgroundColor3 = C.StrokeDim,
                BackgroundTransparency = 0.5,
                BorderSizePixel = 0,
                LayoutOrder = rowCount,
                ZIndex = 3,
            }, page)
            rowCount += 1
            local DivValue = {}
            function DivValue:Set(vis) div.Visible = vis end
            return DivValue
        end

        -- ── Label ─────────────────────────────────
        function Tab:CreateLabel(LabelText, Color)
            local lf = new("Frame", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = Color and Color or C.ElementBG,
                BackgroundTransparency = Color and 0 or 0.4,
                BorderSizePixel = 0,
                LayoutOrder = rowCount,
                ZIndex = 3,
            }, page)
            rowCount += 1

            new("TextLabel", {
                Size = UDim2.new(1, -28, 1, 0),
                Position = UDim2.new(0, 14, 0, 0),
                BackgroundTransparency = 1,
                Text = LabelText,
                TextColor3 = C.Text,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 4,
            }, lf)

            local LV = {}
            function LV:Set(t) lf:FindFirstChildWhichIsA("TextLabel").Text = t end
            return LV
        end

        -- ── Paragraph ─────────────────────────────
        function Tab:CreateParagraph(PSettings)
            local pf = new("Frame", {
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundColor3 = C.ElementBG,
