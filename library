--[[
    Von Hub Library
    A Roblox UI library with accurate Von Hub aesthetic recreation.
    Inspired by Rayfield Interface Suite structure.
    
    Usage:
        local VonLibrary = loadstring(game:HttpGet("YOUR_URL"))()
        local Window = VonLibrary:CreateWindow({ ... })
        local Tab = Window:CreateTab("Tab Name")
        Tab:CreateToggle({ ... })
]]

local VonHub = {}
VonHub.Flags = {}

-- ──────────────────────────────────────────────────
-- Services
-- ──────────────────────────────────────────────────
local function getService(n)
    local s = game:GetService(n)
    if cloneref then
        return cloneref(s)
    else
        return s
    end
end
local TweenService    = getService("TweenService")
local UserInputService = getService("UserInputService")
local RunService      = getService("RunService")
local Players         = getService("Players")
local CoreGui         = getService("CoreGui")
local HttpService     = getService("HttpService")

-- ──────────────────────────────────────────────────
-- Tween Helper
-- ──────────────────────────────────────────────────
local function tween(obj, t, props)
    TweenService:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Exponential), props):Play()
end

