-- ─────────────────────────────────────────────────
-- Gradient Helpers
-- ─────────────────────────────────────────────────
local function makeHorizGrad(frame)
    -- Horizontal: transparent → accent → glow → accent → transparent
    local g = new("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(0.2, C().Stroke),
            ColorSequenceKeypoint.new(0.5, C().AccentGlow),
            ColorSequenceKeypoint.new(0.8, C().Stroke),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(0,0,0)),
        }),
        Rotation = 0,
    }, frame)
    return g
end

local function makeVertGrad(frame)
    local g = new("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(0.2, C().Stroke),
            ColorSequenceKeypoint.new(0.5, C().AccentGlow),
            ColorSequenceKeypoint.new(0.8, C().Stroke),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(0,0,0)),
        }),
        Rotation = 90,
    }, frame)
    return g
end

-- Blue glow dot radial gradient approximation
local function makeGlowDot(parent, size, pos)
    local dot = new("Frame", {
        Size = UDim2.new(0, size, 0, size),
        Position = pos,
        BackgroundColor3 = C().AccentGlow,
        BorderSizePixel = 0,
        ZIndex = 5,
    }, parent)
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, dot)
    -- glow halo
    local halo = new("Frame", {
        Size = UDim2.new(0, size+10, 0, size+10),
        Position = UDim2.new(0.5, -(size+10)/2, 0.5, -(size+10)/2),
        AnchorPoint = Vector2.new(0,0),
        BackgroundColor3 = C().AccentGlow,
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = 4,
    }, dot)
    new("UICorner", { CornerRadius = UDim.new(1, 0) }, halo)
    return dot
end

