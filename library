-- ─────────────────────────────────────────────────
local NotifGui = nil
local function ensureNotifGui()
    if NotifGui and NotifGui.Parent then return end
    NotifGui = new("ScreenGui", {
        Name = "IceHubNotifs",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 210,
    })
    if gethui then NotifGui.Parent = gethui()
    elseif not RunService:IsStudio() then NotifGui.Parent = CoreGui
    else NotifGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui") end
    new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        Padding = UDim.new(0, 8),
    }, NotifGui)
    new("UIPadding", {
        PaddingBottom = UDim.new(0, 18),
        PaddingRight  = UDim.new(0, 18),
    }, NotifGui)
end

function IceHub:Notify(data)
    ensureNotifGui()
    task.spawn(function()
        local T = C()
        local notif = new("Frame", {
            Size            = UDim2.new(0, 290, 0, 0),
            BackgroundColor3 = T.WindowBG,
            BackgroundTransparency = 0,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = 60,
        }, NotifGui)
        new("UICorner", { CornerRadius = UDim.new(0, 8) }, notif)
        new("UIStroke", { Color = T.Stroke, Thickness = 1, Transparency = 0.5 }, notif)

        -- Accent left bar
        local accentBar = new("Frame", {
            Size = UDim2.new(0, 2, 1, 0),
            BackgroundColor3 = T.AccentGlow,
            BorderSizePixel = 0,
            ZIndex = 62,
        }, notif)
        new("UICorner", { CornerRadius = UDim.new(0, 2) }, accentBar)

        -- Glow dot
        local dot = new("Frame", {
            Size = UDim2.new(0, 8, 0, 8),
            Position = UDim2.new(0, 14, 0, 14),
            BackgroundColor3 = T.AccentGlow,
            BorderSizePixel = 0,
            ZIndex = 62,
        }, notif)
        new("UICorner", { CornerRadius = UDim.new(1, 0) }, dot)

        local title = new("TextLabel", {
            Size = UDim2.new(1, -38, 0, 18),
            Position = UDim2.new(0, 28, 0, 8),
            BackgroundTransparency = 1,
            Text = data.Title or "Ice Hub",
            TextColor3 = T.Text,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 62,
        }, notif)

        local content = new("TextLabel", {
            Size = UDim2.new(1, -22, 0, 0),
            Position = UDim2.new(0, 12, 0, 30),
            BackgroundTransparency = 1,
            Text = data.Content or "",
            TextColor3 = T.TextDim,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 62,
        }, notif)

        task.wait()
        local by = content.TextBounds.Y
        local totalH = math.max(by + 46, 54)
        content.Size = UDim2.new(1, -22, 0, by + 4)
        tw(notif, 0.4, { Size = UDim2.new(0, 290, 0, totalH) })
        task.wait(data.Duration or 4)
        tw(notif, 0.3, { BackgroundTransparency = 1, Size = UDim2.new(0, 250, 0, 0) })
        task.wait(0.35)
        notif:Destroy()
    end)
end

