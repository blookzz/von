-- ──────────────────────────────────────────────────
-- Notification System
-- ──────────────────────────────────────────────────
local NotifHolder = nil

local function ensureNotifHolder()
    if NotifHolder and NotifHolder.Parent then return end
    NotifHolder = new("ScreenGui", {
        Name = "VonHubNotifications",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 200,
    })
    local parent
    if gethui then
        parent = gethui()
    elseif not RunService:IsStudio() then
        parent = CoreGui
    else
        parent = Players.LocalPlayer:WaitForChild("PlayerGui")
    end
    NotifHolder.Parent = parent

    new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        Padding = UDim.new(0, 6),
    }, NotifHolder)

    new("UIPadding", {
        PaddingBottom = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 16),
    }, NotifHolder)
end

function VonHub:Notify(data)
    ensureNotifHolder()
    task.spawn(function()
        local notif = new("Frame", {
            Name = "VonNotif",
            Size = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = C.ToastBg,
            BackgroundTransparency = 0.04,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = 50,
        }, NotifHolder)
        new("UICorner", { CornerRadius = UDim.new(0, 6) }, notif)
        new("UIStroke", { Color = C.ToastBorder, Thickness = 1, Transparency = 0.55 }, notif)

        local content = new("TextLabel", {
            Size = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1,
            Text = data.Content or "",
            TextColor3 = C.ToastText,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 51,
        }, notif)
        
        new("UIPadding", {
            PaddingTop = UDim.new(0, 6),
            PaddingBottom = UDim.new(0, 6),
            PaddingLeft = UDim.new(0, 13),
            PaddingRight = UDim.new(0, 13),
        }, notif)

        task.wait()
        local bounds = content.TextBounds
        tween(notif, 0.25, { Size = UDim2.new(0, bounds.X + 26, 0, bounds.Y + 12) })
        task.wait(data.Duration or 2.2)
        tween(notif, 0.25, { BackgroundTransparency = 1 })
        task.wait(0.25)
        notif:Destroy()
    end)
end

