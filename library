                end
            end)

            hexBox.FocusLost:Connect(function()
                local hex = hexBox.Text:gsub("#", "")
                local r, g, b = hex:match("(%w%w)(%w%w)(%w%w)")
                if r then
                    local nc = Color3.fromRGB(tonumber(r, 16), tonumber(g, 16), tonumber(b, 16))
                    h, s, v = nc:ToHSV()
                    updateColor()
                end
            end)

            interact.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    row.Size = UDim2.new(1, 0, 0, 42 + pickerH)
                    tween(pickerFrame, 0.25, { Size = UDim2.new(1, 0, 0, pickerH) })
                else
                    row.Size = UDim2.new(1, 0, 0, 42)
                    tween(pickerFrame, 0.25, { Size = UDim2.new(1, 0, 0, 0) })
                end
            end)

            function CPSettings:Set(c)
                CPSettings.Color = c
                h, s, v = c:ToHSV()
                preview.BackgroundColor3 = c
                hexBox.Text = string.format("#%02X%02X%02X", c.R*255, c.G*255, c.B*255)
            end

            if CPSettings.Flag then VonHub.Flags[CPSettings.Flag] = CPSettings end
            return CPSettings
        end

        return Tab
    end -- CreateTab

    -- ── Destroy ───────────────────────────────────
    function Window:Destroy()
        ScreenGui:Destroy()
    end

    function Window:SetVisibility(vis)
        MainFrame.Visible = vis
        hidden = not vis
    end

    function Window:IsVisible()
        return not hidden
    end

    -- ── Key System ───────────────────────────────
    if Settings.KeySystem and Settings.KeySettings then
        local KS = Settings.KeySettings
        local validKeys = type(KS.Key) == "string" and {KS.Key} or KS.Key or {}
        local keyGui = new("ScreenGui", {
            Name = "VonHubKey",
            ResetOnSpawn = false,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
            DisplayOrder = 150,
        })
        if gethui then keyGui.Parent = gethui()
        elseif not RunService:IsStudio() then keyGui.Parent = CoreGui
        else keyGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui") end

        local keyFrame = new("Frame", {
            Size = UDim2.new(0, 420, 0, 160),
            Position = UDim2.new(0.5, -210, 0.5, -80),
            BackgroundColor3 = C.BG2,
            BorderSizePixel = 0,
            ZIndex = 10,
        }, keyGui)
        new("UICorner", { CornerRadius = UDim.new(0, 10) }, keyFrame)
        new("UIStroke", { Color = C.Stroke, Thickness = 1, Transparency = 0.4 }, keyFrame)

        new("TextLabel", {
            Size = UDim2.new(1, -28, 0, 30),
            Position = UDim2.new(0, 14, 0, 12),
            BackgroundTransparency = 1,
            Text = KS.Title or "Key System",
            TextColor3 = C.Text,
            TextSize = 15,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 11,
        }, keyFrame)

        new("TextLabel", {
            Size = UDim2.new(1, -28, 0, 20),
            Position = UDim2.new(0, 14, 0, 44),
            BackgroundTransparency = 1,
            Text = KS.Note or "Enter your key below",
            TextColor3 = C.TextDim,
            TextSize = 12,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 11,
        }, keyFrame)

        local keyBox = new("TextBox", {
            Size = UDim2.new(1, -28, 0, 32),
            Position = UDim2.new(0, 14, 0, 70),
            BackgroundColor3 = C.InputBG,
            BorderSizePixel = 0,
            PlaceholderText = "Enter key...",
            PlaceholderColor3 = C.TextMuted,
            TextColor3 = C.Text,
            TextSize = 13,
            Font = Enum.Font.Gotham,
            ClearTextOnFocus = false,
            ZIndex = 11,
        }, keyFrame)
        new("UICorner", { CornerRadius = UDim.new(0, 6) }, keyBox)
        new("UIStroke", { Color = C.StrokeDim, Thickness = 1, Transparency = 0.3 }, keyBox)

        local submitBtn = new("TextButton", {
            Size = UDim2.new(1, -28, 0, 30),
            Position = UDim2.new(0, 14, 0, 112),
            BackgroundColor3 = C.Accent,
            BorderSizePixel = 0,
            Text = "Submit",
            TextColor3 = C.White,
            TextSize = 13,
            Font = Enum.Font.GothamBold,
            ZIndex = 11,
        }, keyFrame)
        new("UICorner", { CornerRadius = UDim.new(0, 6) }, submitBtn)

        local passed = false
        -- Check saved key
        if isfile and isfile("VonHub/keys/" .. (KS.FileName or "key") .. ".txt") then
            local savedKey = readfile("VonHub/keys/" .. (KS.FileName or "key") .. ".txt")
            for _, k in ipairs(validKeys) do
                if savedKey == k then passed = true break end
            end
        end

        if not passed then
            MainFrame.Visible = false
            submitBtn.MouseButton1Click:Connect(function()
                local entered = keyBox.Text
                local found = false
                for _, k in ipairs(validKeys) do
                    if entered == k then found = true break end
                end
                if found then
                    if KS.SaveKey and writefile then
                        if not isfolder("VonHub/keys") then makefolder("VonHub/keys") end
                        writefile("VonHub/keys/" .. (KS.FileName or "key") .. ".txt", entered)
                    end
                    keyGui:Destroy()
                    MainFrame.Visible = true
                else
                    tween(keyFrame, 0.1, { BackgroundColor3 = Color3.fromRGB(80, 20, 20) })
                    task.wait(0.3)
                    tween(keyFrame, 0.3, { BackgroundColor3 = C.BG2 })
                end
            end)
        else
            keyGui:Destroy()
        end
    end

    -- Animate in
    MainFrame.BackgroundTransparency = 1
    MainFrame.Size = UDim2.new(0, 400, 0, 60)
    tween(MainFrame, 0.5, { BackgroundTransparency = 0, Size = UDim2.new(0, 620, 0, 400) })

    return Window
end -- CreateWindow

-- ──────────────────────────────────────────────────
-- Load Configuration
-- ──────────────────────────────────────────────────
function VonHub:LoadConfiguration()
    -- Loads saved flags from disk if available
    local loaded = false
    if not (isfile and readfile) then return end
    for flag, elem in pairs(self.Flags) do
        local path = (elem.configFolder or "VonHub") .. "/" .. (elem.configFile or "config") .. ".json"
        if isfile(path) then
            local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
            if ok and data and data[flag] ~= nil then
                pcall(elem.Set, elem, data[flag])
                loaded = true
            end
        end
    end
    if loaded then
        self:Notify({ Title = "Von Hub", Content = "Configuration loaded from previous session.", Duration = 3 })
    end
end

return VonHub
