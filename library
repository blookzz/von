    -- Save / Load helpers
    local function saveCfg()
        if not configEnabled then return end
        local data = {}
        for flag, elem in pairs(VonHub.Flags) do
            if elem.Type == "Toggle" then data[flag] = elem.CurrentValue
            elseif elem.Type == "Slider" then data[flag] = elem.CurrentValue
            elseif elem.Type == "Dropdown" then data[flag] = elem.CurrentOption
            elseif elem.Type == "Keybind" then data[flag] = elem.CurrentKeybind
            elseif elem.Type == "Input" then data[flag] = elem.CurrentValue
            end
        end
        if writefile then
            if not isfolder then return end
            if not isfolder(configFolder) then makefolder(configFolder) end
            writefile(configFolder .. "/" .. configFile .. ".json", HttpService:JSONEncode(data))
        end
    end

