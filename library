        local function renderMini()
            if not miniBody then return end
            -- Clear existing rows
            for _, child in ipairs(miniBody:GetChildren()) do
                if child:IsA("Frame") and child.Name == "MiniRow" then
                    child:Destroy()
                end
            end

            local starredRows = {}
            for _, mr in ipairs(miniRows) do
                if mr.starred then
                    table.insert(starredRows, mr)
                end
            end

            if #starredRows == 0 then
                if miniEmpty then miniEmpty.Visible = true end
                return
            end

            if miniEmpty then miniEmpty.Visible = false end

            for _, mr in ipairs(starredRows) do
                local mRow = new("Frame", {
                    Name = "MiniRow",
                    Size = UDim2.new(1, 0, 0, 24),
