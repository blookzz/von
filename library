            local function applyToggle(val, fireCallback)
                TSettings.CurrentValue = val
                miniRowData.currentValue = val
                if val then
                    tween(toggleTrack, 0.25, { BackgroundColor3 = C.ToggleTrackActiveBg1 })
                    tween(toggleKnob, 0.22, {
                        Position = UDim2.new(0, 24, 0.5, -5.5),
                        BackgroundColor3 = C.ToggleKnobActiveBg1,
                    })
                else
                    tween(toggleTrack, 0.25, { BackgroundColor3 = C.ToggleTrackBg1 })
                    tween(toggleKnob, 0.22, {
                        Position = UDim2.new(0, 5, 0.5, -5.5),
                        BackgroundColor3 = C.ToggleKnobBg1,
                    })
                end
                if miniRowData.updateMini then
                    miniRowData.updateMini(val)
                end
                if fireCallback then
                    local ok, err = pcall(TSettings.Callback, val)
                    if not ok then
                        VonHub:Notify({
                            Title = "Error",
                            Content = tostring(err),
                            Duration = 3,
                        })
                    end
                end
                if TSettings.Flag then saveCfg() end
            end

            -- Set initial state
            applyToggle(TSettings.CurrentValue, false)

            -- Toggle interaction
            local toggleInteract = new("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = 6,
            }, toggleTrack)
            toggleInteract.MouseButton1Click:Connect(function()
                applyToggle(not TSettings.CurrentValue, true)
            end)

            -- X button (clear)
            xBtn.MouseButton1Click:Connect(function()
                currentBind = nil
                isStarred = false
                bindPill.Text = "[..]"
                bindPill.Size = UDim2.new(0, 30, 0, 18)
                updateXBtn()
                updateStarBtn()
                updateMiniStar()
            end)

            xBtn.MouseEnter:Connect(function()
                tween(xBtn, 0.15, { BackgroundColor3 = C.ResetHoverBg1 })
            end)
            xBtn.MouseLeave:Connect(function()
                updateXBtn()
            end)

            -- Star button
            starBtn.MouseButton1Click:Connect(function()
                isStarred = not isStarred
                updateStarBtn()
                updateMiniStar()
                updateXBtn()
            end)

            starBtn.MouseEnter:Connect(function()
                if not isStarred then
                    tween(starBtn, 0.15, { TextColor3 = C.StarHoverText })
                end
            end)
            starBtn.MouseLeave:Connect(function()
                updateStarBtn()
            end)

            -- Bind pill
            bindPill.MouseButton1Click:Connect(function()
                if isListening then return end
                isListening = true
                bindPill.Text = "···"
                bindPill.Size = UDim2.new(0, 30, 0, 18)
                tween(bindPill, 0.2, {
                    TextColor3 = C.BindListeningText,
                })

                local conn
                conn = UserInputService.InputBegan:Connect(function(inp, proc)
                    if inp.KeyCode ~= Enum.KeyCode.Unknown and not proc then
                        local keyName = inp.KeyCode.Name
                        currentBind = keyName
                        miniRowData.bind = keyName
                        bindPill.Text = "[" .. keyName .. "]"
                        bindPill.Size = UDim2.new(0, 40, 0, 18)
                        tween(bindPill, 0.2, { TextColor3 = C.BindBoundText })
                        isListening = false
                        conn:Disconnect()
                        updateXBtn()
                        renderMini()
                        VonHub:Notify({
                            Title = "Bind Set",
                            Content = "Bound to: " .. keyName,
                            Duration = 2.2,
                        })
                    end
                end)
            end)

            bindPill.MouseEnter:Connect(function()
                if not isListening then
                    tween(bindPill, 0.15, { TextColor3 = C.BindHoverText })
                end
            end)
            bindPill.MouseLeave:Connect(function()
                if not isListening then
                    if currentBind then
                        tween(bindPill, 0.15, { TextColor3 = C.BindBoundText })
                    else
                        tween(bindPill, 0.15, { TextColor3 = C.BindText })
                    end
                end
            end)

            -- Set method
            function TSettings:Set(v)
                applyToggle(v, true)
            end

            -- Trigger bound key callbacks
            UserInputService.InputBegan:Connect(function(inp, proc)
                if proc or isListening then return end
                if currentBind and inp.KeyCode == Enum.KeyCode[currentBind] then
                    applyToggle(not TSettings.CurrentValue, true)
                end
            end)

            if TSettings.Flag then
                VonHub.Flags[TSettings.Flag] = TSettings
            end
            return TSettings
        end

        -- ── Slider ────────────────────────────────
        function Tab:CreateSlider(SSettings)
            SSettings.Type = "Slider"
            local row, lbl = makeRow(SSettings.Name or "Slider", rowCount)
            rowCount = rowCount + 1
            row.Size = UDim2.new(1, 0, 0, 54)

            local min, max = SSettings.Range[1], SSettings.Range[2]
            local val = math.clamp(SSettings.CurrentValue or min, min, max)
            local inc = SSettings.Increment or 1

            local valLabel = new("TextLabel", {
                Size = UDim2.new(0, 60, 0, 14),
                Position = UDim2.new(1, -10, 0, 14),
                AnchorPoint = Vector2.new(1, 0),
                BackgroundTransparency = 1,
                Text = tostring(val) .. (SSettings.Suffix and " " .. SSettings.Suffix or ""),
                TextColor3 = C.SepGlow2,
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 4,
            }, row)

            -- Track bar
            local trackBar = new("Frame", {
                Size = UDim2.new(1, -28, 0, 5),
                Position = UDim2.new(0, 14, 0, 34),
                BackgroundColor3 = C.ToggleTrackBg1,
                BorderSizePixel = 0,
                ZIndex = 4,
            }, row)
            new("UICorner", { CornerRadius = UDim.new(0, 3) }, trackBar)
            new("UIStroke", { Color = C.ToggleTrackBorder, Thickness = 1, Transparency = 0.65 }, trackBar)

            local fillBar = new("Frame", {
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = C.SepGlow1,
                BorderSizePixel = 0,
                ZIndex = 5,
            }, trackBar)
            new("UICorner", { CornerRadius = UDim.new(0, 3) }, fillBar)

            local function setSliderVal(newVal, fire)
                newVal = math.clamp(math.floor(newVal / inc + 0.5) * inc, min, max)
                SSettings.CurrentValue = newVal
                local pct = (newVal - min) / (max - min)
                tween(fillBar, 0.1, { Size = UDim2.new(pct, 0, 1, 0) })
                valLabel.Text = tostring(newVal) .. (SSettings.Suffix and " " .. SSettings.Suffix or "")
                if fire then
                    local ok, err = pcall(SSettings.Callback, newVal)
                    if not ok then
                        VonHub:Notify({
                            Title = "Error",
                            Content = tostring(err),
                            Duration = 3,
                        })
                    end
                    if SSettings.Flag then saveCfg() end
                end
            end
            setSliderVal(val, false)

            local draggingSlider = false
            trackBar.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 or
                   inp.UserInputType == Enum.UserInputType.Touch then
                    draggingSlider = true
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)
            RunService.RenderStepped:Connect(function()
                if draggingSlider then
                    local mx = UserInputService:GetMouseLocation().X
                    local ap = trackBar.AbsolutePosition.X
                    local aw = trackBar.AbsoluteSize.X
                    local pct = math.clamp((mx - ap) / aw, 0, 1)
                    setSliderVal(min + pct * (max - min), true)
                end
            end)

            function SSettings:Set(v) setSliderVal(v, true) end

            if SSettings.Flag then VonHub.Flags[SSettings.Flag] = SSettings end
            return SSettings
        end

